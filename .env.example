# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/parental_control?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=change-me-in-production-use-64-char-random-string
JWT_REFRESH_SECRET=change-me-refresh-secret-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Encryption (AES-256-CBC, must be exactly 32 characters)
ENCRYPTION_KEY=change-me-32-char-encryption-key!

# Microsoft OAuth (for Xbox integration)
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=http://localhost:3000/oauth/microsoft/callback

# Firebase Cloud Messaging (for push notifications)
FCM_SERVER_KEY=

# Server
PORT=3000
NODE_ENV=development

# DNS Policy (used by dns-policy module for Redis cache)
# REDIS_HOST and REDIS_PORT above are shared with BullMQ and DNS cache
